{
  "name": "fahausa-org",
  "type": "module",
  "version": "0.0.4",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "bash scripts/db-migrate.sh --local",
    "db:seed:local": "wrangler d1 execute faha-db --local --file=src/db/seed.sql",
    "db:migrate:prod": "bash scripts/db-migrate.sh --remote",
    "db:seed:prod": "wrangler d1 execute faha-db --remote --file=src/db/seed.sql",
    "db:bootstrap": "bash scripts/db-bootstrap.sh",
    "db:reset:local": "rm -rf .wrangler/state && npm run db:migrate:local && npm run db:seed:local",
    "deploy": "npm run build && wrangler pages deploy dist",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "astro": "^5.17.1",
    "drizzle-orm": "^0.45.1",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "wrangler": "^4.50.0"
  }
}
