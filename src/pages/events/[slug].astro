---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import { eq } from 'drizzle-orm';
import { events } from '../../db/schema';

const db = (Astro.locals as any).db;
const { slug } = Astro.params;

if (!db || !slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const [event] = await db.select().from(events).where(eq(events.slug, slug)).limit(1);

if (!event) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const d = new Date(event.dateStart + 'T00:00:00');
const formattedDate = d.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

let descriptionHtml: string | null = null;
if (event.description) {
  descriptionHtml = await marked.parse(event.description);
}
---

<Layout>
  <header id="top-bar">
    <div class="section-inner">
      <h1>Finnish American Home Association</h1>
    </div>
  </header>

  <section class="section-white">
    <div class="section-inner event-page">
      <a href="/#events" class="event-back">&larr; All Events</a>

      {event.imageUrl && (
        <div class="event-hero" style={`background-image: url('${event.imageUrl}')`}></div>
      )}

      <div class="event-detail">
        <div class="event-detail-date">
          <span class="event-detail-weekday">{d.toLocaleDateString('en-US', { weekday: 'long' })}</span>
          <span class="event-detail-day">{d.getDate()}</span>
          <span class="event-detail-monthyear">{d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
        </div>

        <div class="event-detail-content">
          <h2 class="event-detail-title">{event.title}</h2>

          <div class="event-detail-meta">
            {event.timeStart && (
              <div class="event-meta-item">
                <span class="event-meta-label">Time</span>
                <span>{event.timeStart}{event.timeEnd ? ` – ${event.timeEnd}` : ''}</span>
              </div>
            )}
            {event.ticketPrice && (
              <div class="event-meta-item">
                <span class="event-meta-label">Price</span>
                <span>{event.ticketPrice}</span>
              </div>
            )}
            {event.location && (
              <div class="event-meta-item">
                <span class="event-meta-label">Location</span>
                <span>{event.location}</span>
              </div>
            )}
          </div>

          {descriptionHtml && (
            <div class="event-detail-body db-content" set:html={descriptionHtml} />
          )}

          {event.rsvpUrl && (
            <a href={event.rsvpUrl} class="btn btn-dark" target="_blank" rel="noopener" style="margin-top:1.5rem;">RSVP</a>
          )}
        </div>
      </div>
    </div>
  </section>

  <footer id="footer">
    <div class="section-inner">
      <span class="footer-name">Finnish American Home Association</span>
      <div class="social-links">
        <a href="https://www.instagram.com/sonomafaha" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
        <a href="https://www.facebook.com/fahafinn/" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
        <a href="mailto:office@fahausa.org" aria-label="Email">Email</a>
      </div>
    </div>
  </footer>
</Layout>
