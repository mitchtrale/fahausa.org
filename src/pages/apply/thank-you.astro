---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Application Received — Finnish American Home Association" description="Your membership application has been received.">
  <header id="top-bar">
    <div class="section-inner">
      <h1>Finnish American Home Association</h1>
    </div>
  </header>

  <section id="apply" class="section-white">
    <div class="section-inner apply-page apply-thankyou">
      <h2>Application Received</h2>
      <p>
        Thank you for applying to become a member of the Finnish American Home Association!
        We have received your application and will review it shortly.
      </p>
      <p>
        A board member will be in touch with you regarding next steps, including payment
        of your initiation fee and scheduling your introduction to the community.
      </p>
      <p>
        If you have any questions in the meantime, please contact us at
        <a href="mailto:membership@fahausa.org">membership@fahausa.org</a> or
        call <a href="tel:+17079350200">707-935-0200</a>.
      </p>
      <a href="/" class="btn btn-dark" style="margin-top: 1rem;">Back to FAHA</a>
    </div>
  </section>

  <footer id="footer">
    <div class="section-inner">
      <span class="footer-name">Finnish American Home Association</span>
      <div class="social-links">
        <a href="https://www.instagram.com/sonomafaha" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
        <a href="https://www.facebook.com/fahafinn/" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
        <a href="mailto:office@fahausa.org" aria-label="Email">Email</a>
      </div>
    </div>
  </footer>
</Layout>
