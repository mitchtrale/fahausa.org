---
import NewsletterEditor from '../../../components/NewsletterEditor.astro';

const provider = Astro.url.searchParams.get('provider') || 'brevo';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>New Campaign — FAHA Admin</title>
  <link rel="stylesheet" href="/admin.css" />
  <style>
    .container { max-width: 760px; margin: 0 auto; }
  </style>
</head>
<body>
  <nav>
    <strong>FAHA Admin</strong>
    <a href="/admin/events">Events</a>
    <a href="/admin/content">Content</a>
    <a href="/admin/newsletter">Newsletter</a>
    <form method="POST" action="/api/auth/logout" class="logout" style="margin-left:auto;">
      <button type="submit" class="btn-small btn-secondary">Logout</button>
    </form>
  </nav>

  <h1>New Campaign <span style="font-size:0.7em;color:#888;text-transform:uppercase;">({provider})</span></h1>
  <a href="/admin/newsletter" style="font-size:0.9rem;">&larr; All Campaigns</a>

  <div class="container" style="margin-top:1rem;">
    <NewsletterEditor mode="new" provider={provider} />
  </div>
</body>
</html>
