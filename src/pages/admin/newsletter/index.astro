---
import { listCampaigns as listMailchimpCampaigns } from '../../../lib/mailchimp';
import { listCampaigns as listBrevoCampaigns } from '../../../lib/brevo';
import AdminNav from '../../../components/AdminNav.astro';

const env = (Astro.locals as any).env;

let mcCampaigns: any[] = [];
let brevoCampaigns: any[] = [];
let mcError = '';
let brevoError = '';

try {
  const result = await listMailchimpCampaigns(env);
  mcCampaigns = result.campaigns;
} catch (err: any) {
  mcError = err.message;
}

try {
  const result = await listBrevoCampaigns(env);
  brevoCampaigns = result.campaigns || [];
} catch (err: any) {
  brevoError = err.message;
}

function statusBadge(status: string): string {
  const colors: Record<string, string> = {
    save: '#888',
    draft: '#888',
    paused: '#e67e22',
    schedule: '#3498db',
    sending: '#f39c12',
    sent: '#27ae60',
    queued: '#3498db',
    suspended: '#e67e22',
    archive: '#888',
  };
  const color = colors[status] || '#888';
  return `background:${color};color:#fff;padding:2px 8px;border-radius:3px;font-size:0.75rem;text-transform:uppercase;`;
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return '—';
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
  });
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Newsletter — FAHA Admin</title>
  <link rel="stylesheet" href="/admin.css" />
  <style>
    .campaign-list { list-style: none; padding: 0; }
    .campaign-item {
      background: #fff;
      border-radius: 6px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      padding: 1rem 1.25rem;
      margin-bottom: 0.75rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }
    .campaign-info { flex: 1; min-width: 0; }
    .campaign-title {
      font-weight: 600;
      font-size: 0.95rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .campaign-meta { font-size: 0.8rem; color: #888; margin-top: 0.25rem; }
    .campaign-actions { display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0; }
    .btn-sm {
      padding: 0.3rem 0.75rem;
      font-size: 0.8rem;
      border-radius: 3px;
      text-decoration: none;
      color: #fff;
      background: #555;
    }
    .btn-sm:hover { background: #333; }
    .btn-edit { background: #147FB0; }
    .btn-edit:hover { background: #0f6a94; }
    .error-msg { background: #fce4e4; color: #c0392b; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; }
    .empty { text-align: center; color: #888; padding: 2rem 1rem; }
    .provider-section { margin-bottom: 2rem; }
    .provider-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    .provider-header h2 { font-size: 1.1rem; margin: 0; }
    .provider-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 2px 6px;
      border-radius: 3px;
      color: #fff;
    }
    .provider-label-brevo { background: #0b996e; }
    .provider-label-mc { background: #ffe01b; color: #241c15; }
  </style>
</head>
<body>
  <AdminNav />

  <h1>Newsletter</h1>

  <!-- Brevo section -->
  <div class="provider-section">
    <div class="provider-header">
      <h2><span class="provider-label provider-label-brevo">Brevo</span> Campaigns</h2>
      <a href="/admin/newsletter/new?provider=brevo" class="btn btn-small">New Campaign</a>
    </div>

    {brevoError && <div class="error-msg">{brevoError}</div>}

    {brevoCampaigns.length === 0 && !brevoError && (
      <div class="empty">
        <p>No Brevo campaigns yet.</p>
      </div>
    )}

    <ul class="campaign-list">
      {brevoCampaigns.map((c) => (
        <li class="campaign-item">
          <div class="campaign-info">
            <div class="campaign-title">{c.name || c.subject || '(Untitled)'}</div>
            <div class="campaign-meta">
              <span style={statusBadge(c.status)}>{c.status}</span>
              <span style="margin-left:0.5rem;">
                {c.sentDate ? `Sent ${formatDate(c.sentDate)}` : `Created ${formatDate(c.createdAt)}`}
              </span>
            </div>
          </div>
          <div class="campaign-actions">
            {c.status === 'draft' && (
              <a href={`/admin/newsletter/${c.id}?provider=brevo`} class="btn-sm btn-edit">Edit</a>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>

  <!-- Mailchimp section -->
  <div class="provider-section">
    <div class="provider-header">
      <h2><span class="provider-label provider-label-mc">Mailchimp</span> Campaigns</h2>
      <a href="/admin/newsletter/new?provider=mailchimp" class="btn btn-small">New Campaign</a>
    </div>

    {mcError && <div class="error-msg">{mcError}</div>}

    {mcCampaigns.length === 0 && !mcError && (
      <div class="empty">
        <p>No Mailchimp campaigns yet.</p>
      </div>
    )}

    <ul class="campaign-list">
      {mcCampaigns.map((c) => (
        <li class="campaign-item">
          <div class="campaign-info">
            <div class="campaign-title">{c.settings.title || c.settings.subject_line || '(Untitled)'}</div>
            <div class="campaign-meta">
              <span style={statusBadge(c.status)}>{c.status}</span>
              <span style="margin-left:0.5rem;">
                {c.send_time ? `Sent ${formatDate(c.send_time)}` : `Created ${formatDate(c.create_time)}`}
              </span>
            </div>
          </div>
          <div class="campaign-actions">
            {(c.status === 'save' || c.status === 'draft') && (
              <a href={`/admin/newsletter/${c.id}?provider=mailchimp`} class="btn-sm btn-edit">Edit</a>
            )}
            <a href={`https://us7.admin.mailchimp.com/campaigns/edit?id=${c.web_id}`} target="_blank" rel="noopener" class="btn-sm">Mailchimp</a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</body>
</html>
