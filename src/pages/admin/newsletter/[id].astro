---
import { getCampaign as getMailchimpCampaign } from '../../../lib/mailchimp';
import { getCampaign as getBrevoCampaign } from '../../../lib/brevo';
import NewsletterEditor from '../../../components/NewsletterEditor.astro';
import AdminNav from '../../../components/AdminNav.astro';

const { id } = Astro.params;
const provider = Astro.url.searchParams.get('provider') || 'brevo';
let campaign: any = null;
let error = '';

try {
  if (provider === 'mailchimp') {
    campaign = await getMailchimpCampaign(id!);
    if (campaign.status !== 'save' && campaign.status !== 'draft') {
      error = `This campaign has status "${campaign.status}" and cannot be edited here. Use the Mailchimp interface.`;
    }
  } else {
    campaign = await getBrevoCampaign(Number(id));
    if (campaign.status !== 'draft') {
      error = `This campaign has status "${campaign.status}" and cannot be edited here. Use the Brevo dashboard.`;
    }
  }
} catch (err: any) {
  error = err.message;
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Edit Campaign — FAHA Admin</title>
  <link rel="stylesheet" href="/admin.css" />
  <style>
    .container { max-width: 760px; margin: 0 auto; }
    .error-msg { background: #fce4e4; color: #c0392b; padding: 1rem; border-radius: 4px; }
  </style>
</head>
<body>
  <AdminNav />

  <h1>Edit Campaign <span style="font-size:0.7em;color:#888;text-transform:uppercase;">({provider})</span></h1>
  <a href="/admin/newsletter" style="font-size:0.9rem;">&larr; All Campaigns</a>

  <div class="container" style="margin-top:1rem;">
    {error ? (
      <div class="error-msg">
        <p>{error}</p>
        <a href="/admin/newsletter" class="btn" style="margin-top:1rem;display:inline-block;">Back to Campaigns</a>
      </div>
    ) : provider === 'mailchimp' ? (
      <NewsletterEditor
        mode="edit"
        provider="mailchimp"
        campaignId={id}
        initialTitle={campaign.settings.title}
        initialSubject={campaign.settings.subject_line}
        initialPreview={campaign.settings.preview_text}
        webId={campaign.web_id}
      />
    ) : (
      <NewsletterEditor
        mode="edit"
        provider="brevo"
        campaignId={String(campaign.id)}
        initialTitle={campaign.name}
        initialSubject={campaign.subject}
        initialPreview={campaign.previewText || ''}
      />
    )}
  </div>
</body>
</html>
