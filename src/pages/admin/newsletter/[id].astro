---
export const prerender = false;

import { getCampaign } from '../../../lib/mailchimp';
import NewsletterEditor from '../../../components/NewsletterEditor.astro';

const { id } = Astro.params;
let campaign: any = null;
let error = '';

try {
  campaign = await getCampaign(id!);
  if (campaign.status !== 'save' && campaign.status !== 'draft') {
    error = `This campaign has status "${campaign.status}" and cannot be edited here. Use the Mailchimp interface.`;
  }
} catch (err: any) {
  error = err.message;
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Edit Campaign - FAHA Newsletter Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      background: #f5f5f5;
      color: #333;
    }
    .topbar {
      background: #147FB0;
      color: #fff;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar h1 { font-size: 1.125rem; font-weight: 600; }
    .topbar a { color: #fff; text-decoration: none; font-size: 0.875rem; opacity: 0.85; }
    .topbar a:hover { opacity: 1; }
    .container { max-width: 760px; margin: 2rem auto; padding: 0 1rem; }
    .error-msg { background: #fce4e4; color: #c0392b; padding: 1rem; border-radius: 4px; }
    .error-msg .btn { margin-top: 1rem; display: inline-block; padding: 0.5rem 1rem; background: #147FB0; color: #fff; text-decoration: none; border-radius: 4px; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Edit Campaign</h1>
    <a href="/admin/newsletter">&larr; All Campaigns</a>
  </div>
  <div class="container">
    {error ? (
      <div class="error-msg">
        <p>{error}</p>
        <a href="/admin/newsletter" class="btn">Back to Campaigns</a>
      </div>
    ) : (
      <NewsletterEditor
        mode="edit"
        campaignId={id}
        initialTitle={campaign.settings.title}
        initialSubject={campaign.settings.subject_line}
        initialPreview={campaign.settings.preview_text}
        webId={campaign.web_id}
      />
    )}
  </div>
</body>
</html>
